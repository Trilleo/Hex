{
  "schemaVersion": 1,
  "id": "hex",
  "version": "${version}",
  "name": "Hex",
  "description": "A Hypixel Skyblock utility mod",
  "authors": [
    "Trilleo"
  ],
  "contact": {
    "homepage": "https://www.trilleo.net/",
    "sources": "https://github.com/Trilleo/Hex"
  },
  "license": "CC0-1.0",
  "icon": "assets/hex/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "value": "net.trilleo.Hex",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "hex.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}